# GCP Project
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True

# Grocery store (GraphQL API)
STORE_GRAPHQL_URL=https://your-store.com/graphql
STORE_CODE=
STORE_USERNAME=
STORE_PASSWORD=
STORE_CART_URL=https://your-store.com/cart

# Google Docs (grocery brain — long-term memory)
GROCERY_BRAIN_DOC_ID=

# Google OAuth (for Google Docs and Gmail access)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Telegram (via a2a-gateway)
TELEGRAM_BOT_TOKEN=
NUDGE_RECIPIENT_ID=

# Local dev only (set automatically in Cloud Run)
# APP_URL=http://0.0.0.0:8080
# GATEWAY_URL=http://localhost:3000
